#!/usr/bin/env bash
# NotchCast CLI — manage the relay, island, and updates.
set -euo pipefail

CW_DIR="$HOME/.notchcast"
CFG="$CW_DIR/config.json"
LABEL="dev.notchcast.relay"
PLIST="$HOME/Library/LaunchAgents/$LABEL.plist"
CMD="${1:-help}"

# `notchcast setup` must work before any config exists (Homebrew first run:
# brew install → notchcast setup). NOTCHCAST_SRC is baked in by the formula.
if [[ "$CMD" == "setup" ]]; then
  SRC="${NOTCHCAST_SRC:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"
  [[ -f "$SRC/get.sh" ]] || { echo "Can't locate the NotchCast source at $SRC"; exit 1; }
  exec bash "$SRC/get.sh"
fi

[[ -f "$CFG" ]] || { echo "Not set up yet — run: notchcast setup   (or see https://github.com/PShato0x/notchcast)"; exit 1; }

cfg() { node -e "console.log(JSON.parse(require('fs').readFileSync('$CFG','utf8')).$1 ?? '')"; }
SRC="${NOTCHCAST_SRC:-$(cfg srcDir)}"
TOKEN="$(cfg token)"
PORT="$(cfg port)"; PORT="${PORT:-8787}"
[[ -d "$SRC" ]] || { echo "Source missing ($SRC) — re-run: notchcast setup"; exit 1; }

relaunch_island() {
  pkill -x NotchCast 2>/dev/null || true
  sleep 0.5
  open "$SRC/macos/NotchCast.app"
}

case "$CMD" in
  update)
    echo "Current: v$(cat "$SRC/VERSION" 2>/dev/null || echo '?')"
    if [[ ! -e "$SRC/.git" ]]; then
      # Homebrew-managed install: brew owns the source tree.
      echo "Installed via Homebrew — update with:"
      echo "  brew upgrade notchcast && notchcast setup"
      exit 0
    fi
    # get.sh is idempotent: pulls, rebuilds, reinstalls services, relaunches.
    exec bash "$SRC/get.sh"
    ;;
  status)
    curl -sf -H "Authorization: Bearer $TOKEN" "http://127.0.0.1:$PORT/status" | node -e "
let d=''; process.stdin.on('data',c=>d+=c).on('end',()=>{
  const s = JSON.parse(d);
  console.log('NotchCast v' + (s.version || '?')
    + (s.updateAvailable ? '  →  v' + s.latestVersion + ' available (notchcast update)' : '  (up to date)'));
  console.log('Remote approvals: ' + (s.remoteMode ? 'on' : 'off'));
  const live = s.sessions.filter(x => x.state !== 'ended');
  console.log('Sessions: ' + (live.length || 'none'));
  for (const x of live) console.log('  • ' + x.title + ' — ' + x.state + (x.lastPrompt ? '  (' + x.lastPrompt.slice(0,60) + ')' : ''));
  if (s.pending.length) {
    console.log('Pending approvals:');
    for (const p of s.pending) console.log('  ! ' + p.project + ': ' + p.summary);
  }
  console.log('Always-allow rules: ' + s.rules.length);
});" || { echo "Relay not responding on port $PORT — try: notchcast restart"; exit 1; }
    ;;
  restart)
    launchctl kickstart -k "gui/$(id -u)/$LABEL" 2>/dev/null || {
      launchctl bootstrap "gui/$(id -u)" "$PLIST" 2>/dev/null || true
    }
    relaunch_island
    echo "Relay and island restarted."
    ;;
  logs)
    exec tail -n "${2:-50}" -f "$CW_DIR/relay.log"
    ;;
  version)
    cat "$SRC/VERSION" 2>/dev/null || echo dev
    ;;
  uninstall)
    echo "Removing relay service, island, and CLI (keeps ~/.notchcast config + your clone)…"
    launchctl bootout "gui/$(id -u)/$LABEL" 2>/dev/null || true
    rm -f "$PLIST"
    pkill -x NotchCast 2>/dev/null || true
    osascript -e 'tell application "System Events" to delete (every login item whose name is "NotchCast")' >/dev/null 2>&1 || true
    rm -f "$HOME/.local/bin/notchcast"
    echo "Done. To remove the hooks, delete the notchcast entries from ~/.claude/settings.json."
    echo "To remove everything: rm -rf ~/.notchcast"
    ;;
  help|*)
    cat <<'EOF'
notchcast — Claude Code status on your Mac's notch
  setup       first-time setup (or repair): hooks, relay service, island
  status      relay version, sessions, pending approvals
  update      pull the latest version, rebuild, restart
  restart     restart the relay service and the island app
  logs [n]    tail the relay log
  version     print installed version
  uninstall   remove services and app (keeps config)
EOF
    ;;
esac
